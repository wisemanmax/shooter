    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "three": "^0.183.2",
    "three-mesh-bvh": "^0.9.9",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
